#!name= 王者荣耀直连与 DNS 优化
#!desc= 修复王者荣耀相关 gcloud、smoba、tgpa、tdm、smtcdns 等域名掉到 FINAL 走代理；并让相关域名使用系统 DNS，减少国内 CDN 定位异常。
#!author= zijinan / ChatGPT
#!homepage= https://github.com/zijinan/Loon-rule
#!date= 2026-05-25
#!risk= low

[rule]
