[Rule]
# 主站与视频 CDN：走插件内部 PROXY。
# 安装后在插件详情页“代理指向的策略”里把 PROXY 指向可正常访问视频 CDN 的美国节点/全局策略。
DOMAIN-SUFFIX,pornhub.com,PROXY
DOMAIN-SUFFIX,pornhubpremium.com,PROXY
DOMAIN-SUFFIX,phncdn.com,PROXY
DOMAIN-SUFFIX,phprcdn.com,PROXY
DOMAIN-SUFFIX,phncdn.net,PROXY
DOMAIN-SUFFIX,phncdn.org,PROXY

# 排障版不拦广告域名。等确认可以播放后，再逐条加回广告拦截。

[Rewrite]

[Script]

[Mitm]
hostname =
